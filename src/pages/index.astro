---
import Layout from '../layouts/Layout.astro';

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "How much does a new garage door cost in Cranbourne in 2026?",
      "acceptedAnswer": { "@type": "Answer", "text": "Across Cranbourne and the City of Casey, a single garage door (insulated Colorbond sectional or roller) installed with a basic opener typically runs $1,800–$3,000. A double sectional door (5.0–5.4m wide) installed with a quiet belt-drive opener and two remotes runs $2,500–$5,000. Premium options — timber-look sectionals, insulated double-skin panels, smart Wi-Fi openers with battery backup — push a double install to $4,000–$8,000. Standalone motor replacement is $700–$1,600 supplied and fitted. Broken-spring repair is $250–$550 depending on torsion vs extension and how many springs need replacing." }
    },
    {
      "@type": "Question",
      "name": "My garage door spring snapped — can I open it manually?",
      "acceptedAnswer": { "@type": "Answer", "text": "Almost never, and you shouldn't try. A torsion spring stores enough energy to break a wrist if it lets go during a DIY repair, and once a spring is broken the door's full weight (80–180kg for a double sectional) is no longer counterbalanced. The opener will struggle, strip its drive gear, or burn out the motor trying to lift the dead weight. Don't operate the door at all — call us. Same-day emergency call-out across Cranbourne, Berwick, Narre Warren, Hampton Park and Endeavour Hills. Most spring jobs are completed in under 90 minutes on first visit." }
    },
    {
      "@type": "Question",
      "name": "How long does a new garage door installation take in Cranbourne?",
      "acceptedAnswer": { "@type": "Answer", "text": "A straightforward swap-out of an existing door — taking the old sectional or roller off and installing a new one in the same opening — is a 3–5 hour single-trip job. A new opener install (or motor replacement) adds 1–2 hours. A complete new installation including motor, tracks, springs, remotes and Wi-Fi pairing is a single day for a single door, or 1–1.5 days for a double. We always test the door 30 times before leaving site and walk you through the safety reverse, manual release and the smart-opener app pairing." }
    },
    {
      "@type": "Question",
      "name": "Are quiet belt-drive openers worth the extra cost?",
      "acceptedAnswer": { "@type": "Answer", "text": "Yes — and especially so in the Casey growth corridor where so many homes have a bedroom or home office directly above the garage. A chain-drive opener at 5am sounds like a small factory; a quiet belt-drive (Merlin SilentDrive, B&D Smart Phantom, Centurion Reno) is barely audible upstairs. The price difference is typically $150–$250 over a basic chain-drive, and the belt is lower-maintenance. We default to belt-drive on every new install unless the customer specifies otherwise." }
    },
    {
      "@type": "Question",
      "name": "Will my new opener work with Google Home / Alexa / Apple HomeKit?",
      "acceptedAnswer": { "@type": "Answer", "text": "Most current B&D Smart, Merlin MyQ and Centurion smart openers work with Google Home and Alexa via the manufacturer's app and a cloud bridge. Apple HomeKit support is more limited — B&D's HomeKit-certified models work natively, others need a third-party Homebridge plugin. We install and pair the app while we're on site so the door is voice-controlled before we leave. Battery backup is included on premium smart models so the door still opens during a Casey power outage." }
    },
    {
      "@type": "Question",
      "name": "Should I repair my old garage door or replace it?",
      "acceptedAnswer": { "@type": "Answer", "text": "Honest rule of thumb: if the repair cost is under one-third of the cost of a new door, repair. If it's over half, replace. A door under 10 years old with a single broken spring or a stripped opener gear is almost always worth repairing ($250–$900 fixes it). A door 15+ years old with rust at the bottom panel, sagging rollers, multiple bent panels, or a worn-out 1990s opener is usually past economical repair — by the time you fix three things you've spent half the cost of a new insulated Colorbond sectional that'll last 20 years. We tell you straight on the assessment call which side of the line you're on." }
    },
    {
      "@type": "Question",
      "name": "How long do garage doors and openers actually last?",
      "acceptedAnswer": { "@type": "Answer", "text": "A standard Colorbond steel sectional or roller door lasts 20–30 years if the springs are serviced every 5 years and the rollers/cables are kept clean. Springs themselves last 10,000–15,000 cycles — for a family using the door 4 times a day that's roughly 7–10 years. Openers last 12–18 years on average; chain-drives wear faster than belt-drives. The most common failure curve we see across the Casey growth corridor is original builder-grade doors hitting the 8–15 year mark, when the cheap springs go and the original opener needs replacing within a year of each other." }
    },
    {
      "@type": "Question",
      "name": "Do you stock B&D, Steel-Line, Dominator and Centurion?",
      "acceptedAnswer": { "@type": "Answer", "text": "Yes — all four. B&D Doors and Steel-Line are the two most-installed brands in new Casey estates, Dominator does excellent insulated and timber-look sectionals at competitive pricing, and Centurion is the Australian-made favourite for roller doors and smart openers. We're not tied to one manufacturer, so we recommend whichever model fits the opening, the budget and the noise constraints best. Standard panel-door warranties are 5–10 years, motor warranties 5 years on premium belt-drives." }
    }
  ]
};
---
<Layout
  title="Cranbourne Garage Door Co | Install, Repair, Motors | (03) 9003 0108"
  description="Garage door installation, repair and motor replacement for Cranbourne and the City of Casey. New sectional and roller doors, broken-spring emergency repairs, quiet belt-drive motors, smart Wi-Fi openers. B&D, Steel-Line, Dominator, Centurion. Same-day emergency call-out.">
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  </Fragment>

<style>
  /* Image-banner integration (added 2026-06-04) */
  .hero {
    position: relative;
    background-image: linear-gradient(135deg, rgba(15, 23, 42, 0.55), rgba(15, 23, 42, 0.28)), url('/images/hero.jpg');
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    color: #fff;
  }
  .hero h1,
  .hero .hero-sub,
  .hero .hero-eyebrow,
  .hero .hero-trust,
  .hero .accent {
    color: #fff;
  }
  .hero .accent {
    color: #fcd34d;
  }
  .hero .hero-eyebrow {
    color: rgba(255, 255, 255, 0.85);
  }
  .hero .hero-trust {
    color: rgba(255, 255, 255, 0.78);
  }

  .image-banner {
    width: 100%;
    max-height: 460px;
    overflow: hidden;
    margin: 0;
  }
  .image-banner img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 70%;
    display: block;
  }
  .image-banner figcaption {
    background: rgba(15, 23, 42, 0.92);
    color: rgba(255, 255, 255, 0.85);
    padding: 0.85rem 1.25rem;
    text-align: center;
    font-size: 0.95rem;
    margin: 0;
  }
</style>


