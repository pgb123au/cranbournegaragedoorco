      padding: 1.75rem; display: flex; gap: 1.25rem; align-items: center; flex-wrap: wrap;
      box-shadow: 0 2px 8px rgba(0,0,0,0.04);
    }
    .cta-card-primary { background: #1f2937; color: #fff; border-color: #1f2937; }
    .cta-card-primary h3 { color: #fff; }
    .cta-card-body { flex: 1 1 24rem; }
    .cta-card-body h3 { margin: 0 0 0.4rem 0; font-size: 1.35rem; line-height: 1.3; }
    .cta-card-body p { margin: 0; }
    .cta-card-actions { display: flex; gap: 0.65rem; flex-wrap: wrap; }
    .btn-large { padding: 0.85rem 1.5rem; font-size: 1.05rem; }
    .faq-list { max-width: 60rem; margin: 1rem auto; }
    .faq-item { border-bottom: 1px solid #e5e7eb; padding: 0.85rem 0; }
    .faq-item[open] { background: rgba(0,0,0,0.02); }
    .faq-q { cursor: pointer; padding: 0.4rem 0.5rem; font-size: 1.05rem; }
    .faq-q:hover { color: #047857; }
    .faq-a { padding: 0.65rem 0.5rem 0.85rem 0.5rem; line-height: 1.7; color: #4b5563; }

  </style>
</Layout>
