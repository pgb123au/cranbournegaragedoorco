---
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogType?: string;
}

const SITE = 'https://cranbournegaragedoorco.com.au';
const PHONE_DISPLAY = '(03) 9003 0108';
const PHONE_TEL = '+61390030108';
const EMAIL = 'quotes@cranbournegaragedoorco.com.au';
const BIZ_NAME = 'Cranbourne Garage Door Co';

const { title, description, canonical = SITE + '/', ogType = 'website' } = Astro.props;

const localBusinessSchema = {
  "@context": "https://schema.org",
  "@type": "GeneralContractor",
  "@id": SITE + "/#business",
  "name": BIZ_NAME,
  "image": SITE + "/images/og-image.jpg",
  "url": SITE,
  "telephone": PHONE_TEL,
  "priceRange": "$$",
  "description": "Garage door installation, repair and motor replacement for Cranbourne and the City of Casey. New sectional, roller and tilt doors, broken spring repair, quiet belt-drive motor upgrades, smart openers. B&D, Steel-Line, Dominator, Centurion. Same-day emergency call-outs. Fully insured, AS 4505 compliant.",
  "areaServed": [
    { "@type": "City", "name": "Cranbourne", "containedInPlace": { "@type": "AdministrativeArea", "name": "City of Casey" } },
    { "@type": "City", "name": "Berwick" },
    { "@type": "City", "name": "Narre Warren" },
    { "@type": "City", "name": "Hampton Park" },
    { "@type": "City", "name": "Endeavour Hills" },
    { "@type": "City", "name": "Cranbourne East" },
    { "@type": "City", "name": "Cranbourne West" },
    { "@type": "City", "name": "Cranbourne North" },
    { "@type": "City", "name": "Cranbourne Park" }
  ],
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Cranbourne",
    "addressRegion": "VIC",
    "postalCode": "3977",
    "addressCountry": "AU"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": -38.0989,
    "longitude": 145.2810
  },
  "openingHoursSpecification": [{
    "@type": "OpeningHoursSpecification",
    "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday","Saturday"],
    "opens": "07:00",
    "closes": "18:00"
  }],
  "hasOfferCatalog": {
    "@type": "OfferCatalog",
    "name": "Garage Door Installation, Repair & Motor Services",
    "itemListElement": [
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Garage Door Installation" }},
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Garage Door Repair" }},
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Motor Replacement" }},
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Sectional Doors" }},
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Roller Doors" }}
    ]
  }
};

const websiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "@id": SITE + "/#website",
  "url": SITE + "/",
  "name": BIZ_NAME,
  "inLanguage": "en-AU",
  "publisher": { "@id": SITE + "/#business" }
};
// BreadcrumbList JSON-LD auto-generated from Astro.url.pathname
const pathname = Astro.url.pathname;
const breadcrumbSegments = pathname.split('/').filter(Boolean);
const breadcrumbItems = [{ "@type": "ListItem", "position": 1, "name": "Home", "item": SITE + "/" }];
let cumulative = SITE;
breadcrumbSegments.forEach((seg, i) => {
  cumulative += '/' + seg;
  // Human-friendly name: kebab → Title Case, special-case 'services' → Services
  const friendly = seg === 'services'
    ? 'Services'
    : seg.replace(/-/g, ' ').replace(/\b\w/g, (c) => c.toUpperCase());
  breadcrumbItems.push({
    "@type": "ListItem",
    "position": i + 2,
    "name": friendly,
    "item": cumulative + '/'
  });
});
const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": breadcrumbItems
};

---
<!DOCTYPE html>
<html lang="en-AU">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{title}</title>
  <meta name="description" content={description}>
  <link rel="canonical" href={canonical}>
  <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1">
  <meta name="theme-color" content="#1C1C24">

  <meta property="og:type" content={ogType}>
  <meta property="og:title" content={title}>
  <meta property="og:description" content={description}>
  <meta property="og:url" content={canonical}>
  <meta property="og:locale" content="en_AU">
  <meta property="og:site_name" content={BIZ_NAME}>
  <meta property="og:image" content={SITE + "/images/og-image.jpg"}>
  <meta property="og:image:secure_url" content={SITE + "/images/og-image.jpg"}>
  <meta property="og:image:type" content="image/jpeg">
  <meta property="og:image:width" content="1200">
  <meta property="og:image:height" content="630">
  <meta property="og:image:alt" content={BIZ_NAME + " — free quote, call today"}>

  <meta name="twitter:card" content="summary_large_image">
